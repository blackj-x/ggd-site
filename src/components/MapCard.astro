---
import { sizeLabel, type GameMap } from '../data/maps';
export interface Props { map: GameMap }
const { map } = Astro.props;
const featList = [
  map.features.hasVents ? '通风管' : '无通风管',
  map.features.hasCCTV ? '有监控' : null,
  map.features.dayNight ? '昼夜循环' : null,
  map.features.corruption ? '腐化' : null,
].filter(Boolean) as string[];
---
<a class="map-card" href={`/maps/${map.slug}`}>
  <div class="map-card-top">
    <span class="theme-badge">{map.theme}</span>
    <span class="size-badge">{sizeLabel[map.size]}</span>
  </div>
  <h3>{map.name}</h3>
  <div class="map-en">{map.nameEn}</div>
  <p class="map-desc">{map.summary}</p>
  <div class="map-foot">
    {featList.map((f) => <span class="feat-tag">{f}</span>)}
  </div>
</a>

<style>
  .map-card{display:block;background:var(--bg-card);border:1px solid var(--line);border-radius:16px;padding:20px;transition:.18s;position:relative;overflow:hidden}
  .map-card::before{content:"";position:absolute;inset:0 0 auto 0;height:4px;background:linear-gradient(90deg,var(--goose),var(--neutral),var(--duck))}
  .map-card:hover{transform:translateY(-5px);border-color:var(--txt-dim);box-shadow:0 14px 38px -10px rgba(176,107,255,.55)}
  .map-card-top{display:flex;gap:8px;margin-bottom:12px}
  .theme-badge{font-size:11px;font-weight:700;padding:4px 10px;border-radius:7px;background:rgba(176,107,255,.16);color:var(--neutral)}
  .size-badge{font-size:11px;padding:4px 10px;border-radius:7px;background:var(--bg-elev);color:var(--txt-dim);border:1px solid var(--line)}
  .map-card h3{font-size:19px;font-weight:700;margin-bottom:2px}
  .map-en{font-size:12px;color:var(--txt-dim);margin-bottom:10px}
  .map-desc{font-size:13.5px;color:var(--txt-dim);min-height:60px}
  .map-foot{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px}
  .feat-tag{font-size:11px;color:var(--txt-dim);background:var(--bg-elev);border:1px solid var(--line);padding:3px 9px;border-radius:6px}
</style>
