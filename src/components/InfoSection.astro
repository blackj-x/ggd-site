---
export interface Props {
  title: string;
  icon?: string;
  /** 可选变体：默认、highlight、compact */
  variant?: 'default' | 'highlight' | 'compact';
}

const { title, icon, variant = 'default' } = Astro.props;
const className = `info-sec ${variant}`;
---

<section class={className}>
  <h2>
    {icon && <span class="icon">{icon}</span>}
    {title}
  </h2>
  <slot />
</section>

<style>
  .info-sec {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    margin-bottom: var(--space-4);
  }

  .info-sec h2 {
    font-size: 17px;
    color: var(--accent);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .info-sec .icon {
    font-size: 18px;
  }

  .info-sec p {
    font-size: 15.5px;
    line-height: 1.65;
  }

  .info-sec ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 0;
    padding: 0;
  }

  .info-sec li {
    font-size: 15px;
    color: var(--txt-dim);
    padding-left: 20px;
    position: relative;
  }

  .info-sec li::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  /* 变体 */
  .info-sec.highlight {
    border-color: var(--accent);
    background: linear-gradient(145deg, var(--bg-card), #2a254a);
  }

  .info-sec.compact {
    padding: var(--space-4);
  }

  .info-sec.compact h2 {
    font-size: 15px;
    margin-bottom: 8px;
  }
</style>