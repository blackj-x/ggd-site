---
import { campName, stars, type Role } from '../data/roles';
export interface Props { role: Role }
const { role } = Astro.props;
---
<a class="card" data-camp={role.camp} href={`/roles/${role.slug}/`}>
  <div class="card-top">
    <div class="avatar">{role.icon}</div>
    <span class={`badge ${role.camp}`}>{campName[role.camp]}</span>
  </div>
  <h3>{role.name}{role.canKill && <span class="knife" title="带刀"> 🔪</span>}</h3>
  <div class="role-en">{role.nameEn}</div>
  <p class="desc">{role.summary}</p>
  <div class="card-foot">
    {(role.tags ?? []).map((t) => <span class="tag">{t}</span>)}
    <span class="diff" title="官方难度">{stars(role.difficulty)}</span>
  </div>
</a>
