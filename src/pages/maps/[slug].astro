---
import Base from '../../layouts/Base.astro';
import AdSlot from '../../components/AdSlot.astro';
import { maps, getMap, annotationTypes, sizeLabel, type GameMap } from '../../data/maps';

export function getStaticPaths() {
  return maps.map((map) => ({ params: { slug: map.slug }, props: { map } }));
}
const { map } = Astro.props as { map: GameMap };

const title = `${map.name}（${map.nameEn}）地图攻略与点位 - 鹅鸭杀`;
const description = `鹅鸭杀${map.theme}主题地图「${map.name}」攻略：${map.summary} 含舱室布局、任务点位、刀点盲区与分阵营打法。`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: title,
      description,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '首页', item: new URL('/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: '地图攻略', item: new URL('/maps', Astro.site).href },
        { '@type': 'ListItem', position: 3, name: map.name },
      ],
    },
  ],
};

// 机制特性展示
const featRows: [string, string][] = [
  ['通风管', map.features.hasVents ? '有' : '无'],
  ['监控', map.features.hasCCTV ? '有' : '无'],
  ['监狱机制', map.features.hasJail ? '有' : '无'],
  ['前置任务', map.features.hasPreTask ? '有' : '无'],
  ['昼夜循环', map.features.dayNight ? '有' : '无'],
  ['腐化机制', map.features.corruption ? '有' : '无'],
  ['藏尸区', map.features.disposalAreas > 0 ? `${map.features.disposalAreas} 处` : '无'],
];
const campMeta = [
  { key: 'goose', name: '鹅阵营', color: 'var(--goose)' },
  { key: 'duck', name: '鸭阵营', color: 'var(--duck)' },
  { key: 'neutral', name: '中立', color: 'var(--neutral)' },
] as const;

const related = maps.filter((m) => m.theme === map.theme && m.slug !== map.slug).slice(0, 3);
const ogImg = map.image ? map.image.replace(/\.svg$/, '.png') : undefined;
---
<Base title={title} description={description} jsonLd={jsonLd} active="maps" ogImage={ogImg}>
  <div class="wrap detail">
    <div class="crumb"><a href="/">首页</a> / <a href="/maps">地图攻略</a> / {map.name}</div>

    <header class="map-head">
      <div>
        <div class="badges">
          <span class="theme-badge">{map.theme}</span>
          <span class="size-badge">{sizeLabel[map.size]}地图</span>
        </div>
        <h1>{map.name}</h1>
        <div class="map-en">{map.nameEn}</div>
      </div>
    </header>
    <p class="lead">{map.summary}</p>

    <AdSlot variant="top" label="广告位 · 内容顶部 728×90" />

    <div class="detail-layout">
      <main>
        {map.image ? (
          <section class="sec map-viewer-sec">
            <h2>🗺️ 舱室示意图</h2>
            <p class="hint">把鼠标移到标注点上查看说明（移动端点击）。</p>
            <div class="map-viewer">
              <img src={map.image} alt={`${map.name}舱室示意图`} width={map.imageW} height={map.imageH} loading="lazy" decoding="async" />
              {(map.annotations ?? []).map((a) => {
                const t = annotationTypes[a.type];
                return (
                  <button class="pin" style={`left:${a.x}%;top:${a.y}%;--pc:${t?.color ?? '#fff'}`} aria-label={a.label}>
                    <span class="pin-dot"></span>
                    <span class="pin-pop">
                      <strong>{t?.icon} {a.label}</strong>
                      {a.note && <em>{a.note}</em>}
                    </span>
                  </button>
                );
              })}
            </div>
            <div class="legend">
              {[...new Set((map.annotations ?? []).map((a) => a.type))].map((tp) => (
                <span class="leg"><i style={`background:${annotationTypes[tp]?.color}`}></i>{annotationTypes[tp]?.name}</span>
              ))}
            </div>
          </section>
        ) : (
          <section class="sec"><p class="hint">该地图示意图建设中，可先查看下方文字攻略。</p></section>
        )}

        {map.strategy && (
          <section class="sec">
            <h2>🎯 分阵营打法</h2>
            <div class="camp-strats">
              {campMeta.map((c) => {
                const items = (map.strategy as any)?.[c.key] as string[] | undefined;
                return items && items.length > 0 ? (
                  <div class="camp-strat" style={`--cc:${c.color}`}>
                    <h3>{c.name}</h3>
                    <ul>{items.map((s) => <li>{s}</li>)}</ul>
                  </div>
                ) : null;
              })}
            </div>
          </section>
        )}

        {map.tips && map.tips.length > 0 && (
          <section class="sec">
            <h2>💡 速记要点</h2>
            <ul class="tips">{map.tips.map((t) => <li>{t}</li>)}</ul>
          </section>
        )}
      </main>

      <aside>
        <div class="sec mini">
          <h2>📊 地图机制</h2>
          <table class="feat-table">
            {featRows.map(([k, v]) => (
              <tr><td>{k}</td><td class={v === '无' ? 'no' : 'yes'}>{v}</td></tr>
            ))}
          </table>
          {map.features.mapSabotages.length > 0 && (
            <div class="sabos">
              <span class="sabo-title">专属破坏/危险</span>
              {map.features.mapSabotages.map((s) => <span class="sabo">{s}</span>)}
            </div>
          )}
        </div>
        <AdSlot variant="side" />
        {related.length > 0 && (
          <div class="sec mini">
            <h2>🔗 同主题地图</h2>
            {related.map((m) => (
              <a class="rel" href={`/maps/${m.slug}`}>{m.name} <span>{m.nameEn}</span></a>
            ))}
          </div>
        )}
      </aside>
    </div>
  </div>
</Base>

<style>
  .detail{padding-top:24px}
  .map-head{display:flex;justify-content:space-between;align-items:flex-end;padding-top:8px}
  .badges{display:flex;gap:8px;margin-bottom:10px}
  .theme-badge{font-size:12px;font-weight:700;padding:5px 12px;border-radius:8px;background:rgba(176,107,255,.16);color:var(--neutral)}
  .size-badge{font-size:12px;padding:5px 12px;border-radius:8px;background:var(--bg-elev);color:var(--txt-dim);border:1px solid var(--line)}
  .map-head h1{font-size:36px;font-weight:900}
  .map-en{font-size:14px;color:var(--txt-dim);margin-top:2px}
  .lead{color:var(--txt-dim);font-size:16px;margin:14px 0 4px;max-width:720px}
  .detail-layout{display:grid;grid-template-columns:1fr 300px;gap:28px;margin-bottom:40px}
  .sec{background:var(--bg-card);border:1px solid var(--line);border-radius:16px;padding:22px;margin-bottom:18px}
  .sec h2{font-size:17px;color:var(--accent);margin-bottom:12px}
  .hint{font-size:13px;color:var(--txt-dim);margin-bottom:14px}

  /* 地图查看器：底图 + 标注点 */
  .map-viewer{position:relative;line-height:0;border-radius:12px;overflow:hidden;border:1px solid var(--line)}
  .map-viewer img{width:100%;height:auto;display:block}
  .pin{position:absolute;transform:translate(-50%,-50%);background:none;border:none;cursor:pointer;padding:0;z-index:1}
  .pin-dot{display:block;width:16px;height:16px;border-radius:50%;background:var(--pc);box-shadow:0 0 0 3px rgba(0,0,0,.35),0 0 12px -1px var(--pc);transition:.15s}
  .pin:hover{z-index:5}
  .pin:hover .pin-dot{transform:scale(1.4)}
  .pin-pop{position:absolute;bottom:140%;left:50%;transform:translateX(-50%);background:var(--bg-elev);border:1px solid var(--pc);border-radius:10px;padding:9px 12px;width:200px;text-align:left;opacity:0;pointer-events:none;transition:.15s;line-height:1.5;z-index:10}
  .pin:hover .pin-pop,.pin:focus .pin-pop{opacity:1}
  .pin-pop strong{display:block;font-size:13px;color:var(--txt);margin-bottom:3px}
  .pin-pop em{font-size:12px;color:var(--txt-dim);font-style:normal}
  .legend{display:flex;gap:14px;flex-wrap:wrap;margin-top:14px}
  .leg{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--txt-dim)}
  .leg i{width:11px;height:11px;border-radius:50%}

  /* 分阵营攻略 */
  .camp-strats{display:flex;flex-direction:column;gap:14px}
  .camp-strat{border-left:3px solid var(--cc);padding-left:14px}
  .camp-strat h3{font-size:15px;color:var(--cc);margin-bottom:8px}
  .camp-strat ul{list-style:none;display:flex;flex-direction:column;gap:7px}
  .camp-strat li{font-size:14px;color:var(--txt-dim);padding-left:16px;position:relative}
  .camp-strat li::before{content:"▸";position:absolute;left:0;color:var(--cc)}
  .tips{list-style:none;display:flex;flex-direction:column;gap:9px}
  .tips li{font-size:14.5px;color:var(--txt-dim);padding-left:18px;position:relative}
  .tips li::before{content:"▸";position:absolute;left:0;color:var(--accent)}

  /* 侧栏机制表 */
  .mini h2{font-size:15px}
  .feat-table{width:100%;border-collapse:collapse}
  .feat-table td{padding:7px 0;font-size:13.5px;border-bottom:1px solid var(--line)}
  .feat-table td:first-child{color:var(--txt-dim)}
  .feat-table td.yes{color:var(--accent);text-align:right;font-weight:700}
  .feat-table td.no{color:var(--txt-dim);text-align:right}
  .sabos{margin-top:14px;display:flex;flex-wrap:wrap;gap:6px;align-items:center}
  .sabo-title{font-size:12px;color:var(--txt-dim);width:100%;margin-bottom:4px}
  .sabo{font-size:11px;background:rgba(251,146,60,.16);color:#fb923c;padding:3px 9px;border-radius:6px}
  .rel{display:block;padding:9px 0;border-bottom:1px solid var(--line);font-size:14px}
  .rel:last-child{border:0}
  .rel span{color:var(--txt-dim);font-size:12px}
  .rel:hover{color:var(--accent)}

  @media(max-width:920px){
    .detail-layout{grid-template-columns:1fr}
    .ad-side{display:none}
    .map-head h1{font-size:28px}
    .pin-pop{width:160px}
  }
</style>
