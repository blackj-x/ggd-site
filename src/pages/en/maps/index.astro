---
import Base from '../../../layouts/Base.astro';
import AdSlot from '../../../components/AdSlot.astro';
import MapCard from '../../../components/MapCard.astro';
import { getLocalizedMaps } from '../../../data/maps';
import { getUI } from '../../../i18n/config';

const lang = 'en';
const maps = getLocalizedMaps(lang);
const ui = getUI(lang);

const title = 'Map Guides - Goose Goose Duck Guide';
const description = 'Goose Goose Duck full map guides: 12 maps with cabin layouts, task points, kill spots, blind spots, mechanics and faction strategies. Click for annotated diagrams.';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
};
// Group by theme (themes already localized for 'en')
const themes = [...new Set(maps.map((m) => m.theme))];
---
<Base title={title} description={description} jsonLd={jsonLd} active="maps" lang={lang}>
  <div class="wrap">
    <section class="hero retro-hero">
      <div class="crumb"><a href="/en/">{ui.home}</a> / {ui.maps}</div>
      <h1>
        <span class="title-main">Map</span>
        <span class="em">Guides</span>
      </h1>
      <p class="sub">12 maps with cabin layouts, task points, kill spots &amp; blind spots, mechanics and faction-specific strategies. Click any map for the annotated diagram.</p>
      <div class="hero-stats">
        <span class="stat">12 Maps</span>
        <span class="stat">Annotated</span>
      </div>
    </section>

    <AdSlot variant="top" />

    {themes.map((theme) => (
      <section class="theme-group fade-in">
        <h2 class="theme-title">{theme} <span class="count">({maps.filter((m) => m.theme === theme).length})</span></h2>
        <div class="map-grid">
          {maps.filter((m) => m.theme === theme).map((map) => <MapCard map={map} lang={lang} />)}
        </div>
      </section>
    ))}
  </div>
</Base>

<style>
  .hero{padding:46px 0 26px}
  .retro-hero h1{font-size:44px;font-weight:900;letter-spacing:-1px}
  .retro-hero .title-main{display:block}
  .retro-hero h1 .em{background:linear-gradient(120deg,var(--goose),var(--neutral) 50%,var(--duck));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
  .retro-hero .sub{color:var(--txt-dim);margin-top:10px;max-width:640px}
  .hero-stats{display:flex;gap:12px;margin-top:14px;font-size:12px}
  .hero-stats .stat{padding:4px 10px;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,0.03);color:var(--txt-dim)}
  .theme-group{margin-bottom:36px}
  .theme-title{font-size:18px;color:var(--accent);margin-bottom:16px;padding-left:12px;border-left:3px solid var(--accent);display:flex;align-items:center;gap:8px}
  .theme-title .count{font-size:13px;color:var(--txt-dim);font-weight:400}
  .map-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
  @media(max-width:920px){h1{font-size:30px}}
</style>
