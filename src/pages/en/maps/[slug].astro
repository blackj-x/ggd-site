---
import Base from '../../../layouts/Base.astro';
import AdSlot from '../../../components/AdSlot.astro';
import InfoSection from '../../../components/InfoSection.astro';
import { getMap, getLocalizedMaps, getAnnotationTypes, getSizeLabel } from '../../../data/maps';
import { getUI } from '../../../i18n/config';

export function getStaticPaths() {
  const allMaps = getLocalizedMaps('zh');
  return allMaps.map((m) => ({ 
    params: { slug: m.slug }, 
    props: { slug: m.slug } 
  }));
}

const { slug } = Astro.params;
const lang = 'en';
const map = getMap(slug as string, lang);
if (!map) return Astro.redirect('/en/maps/');

const ui = getUI(lang);
const annotTypes = getAnnotationTypes(lang);

const title = `${map.name} Map Guide & Points - Goose Goose Duck`;
const description = `Goose Goose Duck ${map.theme} map "${map.name}": ${map.summary} Includes layouts, task locations, kill spots, blind spots and faction strategies.`;

const ogImg = map.image ? map.image.replace(/\.svg$/, '.png') : undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: title,
      description,
      image: ogImg ? new URL(ogImg, Astro.site).href : undefined,
      author: { '@type': 'Organization', name: 'Goose Goose Duck Guide' },
      publisher: { '@type': 'Organization', name: 'Goose Goose Duck Guide' },
      dateModified: map.updatedAt || '2026-06-06',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/en/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: 'Maps', item: new URL('/en/maps/', Astro.site).href },
        { '@type': 'ListItem', position: 3, name: map.name },
      ],
    },
  ],
};

// Map mechanics rows (localized)
const featRows: [string, string][] = [
  ['Vents', map.features.hasVents ? 'Yes' : 'No'],
  ['CCTV', map.features.hasCCTV ? 'Yes' : 'No'],
  ['Jail', map.features.hasJail ? 'Yes' : 'No'],
  ['Pre-Task', map.features.hasPreTask ? 'Yes' : 'No'],
  ['Day/Night', map.features.dayNight ? 'Yes' : 'No'],
  ['Corruption', map.features.corruption ? 'Yes' : 'No'],
  ['Disposal Areas', map.features.disposalAreas > 0 ? `${map.features.disposalAreas}` : 'None'],
];
const campMeta = [
  { key: 'goose', name: 'Geese', color: 'var(--goose)' },
  { key: 'duck', name: 'Ducks', color: 'var(--duck)' },
  { key: 'neutral', name: 'Neutral', color: 'var(--neutral)' },
] as const;

const related = getLocalizedMaps(lang).filter((m) => m.theme === map.theme && m.slug !== map.slug).slice(0, 3);
---
<Base title={title} description={description} jsonLd={jsonLd} active="maps" ogImage={ogImg} lang={lang}>
  <div class="wrap detail">
    <div class="crumb"><a href="/en/">{ui.home}</a> / <a href="/en/maps/">{ui.maps}</a> / {map.name}</div>

    <header class="map-head retro-head">
      <div>
        <div class="badges">
          <span class="theme-badge">{map.theme}</span>
          <span class="size-badge">{getSizeLabel(map.size, lang)} Map</span>
        </div>
        <h1 class="neon-title">{map.name}</h1>
        <div class="map-en">{map.nameEn}</div>
        <div class="meta">Updated: {map.updatedAt || '2026-06-06'} · Versions: Base / Corruption</div>
      </div>
    </header>
    <p class="lead">{map.summary}</p>

    <AdSlot variant="top" label="Ad slot · Content top 728×90" />

    <div class="detail-layout">
      <main>
        {map.image ? (
          <InfoSection title="Annotated Diagram" icon="🗺️" variant="highlight">
            <p class="hint">Hover pins for details (tap on mobile). Click a legend item to highlight matching pins.</p>
            <div class="map-viewer" id="map-viewer">
              <img src={map.image} alt={`${map.name} cabin diagram`} width={map.imageW} height={map.imageH} loading="lazy" decoding="async" class="img-enhanced" />
              {(map.annotations ?? []).map((a, i) => {
                const t = annotTypes[a.type];
                return (
                  <button 
                    class="pin" 
                    data-type={a.type}
                    style={`left:${a.x}%;top:${a.y}%;--pc:${t?.color ?? '#fff'}`} 
                    aria-label={a.label}
                  >
                    <span class="pin-dot"></span>
                    <span class="pin-pop">
                      <strong>{t?.icon} {a.label}</strong>
                      {a.note && <em>{a.note}</em>}
                    </span>
                  </button>
                );
              })}
            </div>
            <div class="legend" id="legend">
              {[...new Set((map.annotations ?? []).map((a) => a.type))].map((tp) => (
                <button class="leg" data-type={tp}>
                  <i style={`background:${annotTypes[tp]?.color}`}></i>
                  {annotTypes[tp]?.name}
                </button>
              ))}
            </div>
          </InfoSection>
        ) : (
          <InfoSection title="Diagram Coming Soon" icon="🗺️">
            <p class="hint">Diagram for this map is under construction. See the text strategies below.</p>
          </InfoSection>
        )}

        {map.strategy && (
          <InfoSection title="Faction Strategies" icon="🎯">
            <div class="camp-strats">
              {campMeta.map((c) => {
                const items = (map.strategy as any)?.[c.key] as string[] | undefined;
                return items && items.length > 0 ? (
                  <div class="camp-strat" style={`--cc:${c.color}`}>
                    <h3>{c.name}</h3>
                    <ul>{items.map((s) => <li>{s}</li>)}</ul>
                  </div>
                ) : null;
              })}
            </div>
          </InfoSection>
        )}

        {map.tips && map.tips.length > 0 && (
          <InfoSection title="Quick Tips" icon="💡" variant="compact">
            <ul class="tips">{map.tips.map((t) => <li>{t}</li>)}</ul>
          </InfoSection>
        )}
      </main>

      <aside>
        <div class="sec mini">
          <h2>📊 Map Mechanics</h2>
          <table class="feat-table">
            {featRows.map(([k, v]) => (
              <tr><td>{k}</td><td class={(v === 'No' || v === 'None') ? 'no' : 'yes'}>{v}</td></tr>
            ))}
          </table>
          {map.features.mapSabotages.length > 0 && (
            <div class="sabos">
              <span class="sabo-title">Unique Sabotages / Hazards</span>
              {map.features.mapSabotages.map((s) => <span class="sabo">{s}</span>)}
            </div>
          )}
        </div>
        <AdSlot variant="side" />
        {related.length > 0 && (
          <div class="sec mini">
            <h2>🔗 Same Theme Maps</h2>
            {related.map((m) => (
              <a class="rel" href={`/en/maps/${m.slug}/`}>{m.name} <span>{m.nameEn}</span></a>
            ))}
          </div>
        )}
        <div class="sec mini">
          <h2>🔗 Recommended Roles</h2>
          <a class="rel" href="/en/roles/priest/">Priest</a>
          <a class="rel" href="/en/roles/demon-hunter/">Demon Hunter</a>
          <a class="rel" href="/en/roles/locksmith/">Locksmith</a>
          <a class="rel" href="/en/roles/sheriff/">Sheriff</a>
          <a class="rel" href="/en/roles/detective/">Detective</a>
          <a class="rel" href="/en/roles/assassin/">Assassin</a>
        </div>
      </aside>
    </div>
  </div>

  <!-- Map legend highlight interaction -->
  <script is:inline>
    const viewer = document.getElementById('map-viewer');
    const legend = document.getElementById('legend');
    if (viewer && legend) {
      const pins = viewer.querySelectorAll('.pin');
      const legs = legend.querySelectorAll('.leg');

      function highlight(type) {
        pins.forEach(p => {
          if (p.dataset.type === type) {
            p.classList.add('active');
          } else {
            p.classList.remove('active');
          }
        });
        legs.forEach(l => l.classList.toggle('active', l.dataset.type === type));
      }

      function clear() {
        pins.forEach(p => p.classList.remove('active'));
        legs.forEach(l => l.classList.remove('active'));
      }

      legs.forEach(leg => {
        leg.addEventListener('click', () => {
          const type = leg.dataset.type;
          if (leg.classList.contains('active')) {
            clear();
          } else {
            highlight(type);
          }
        });
      });

      // Click viewer or image to clear
      viewer.addEventListener('click', (e) => {
        if (e.target === viewer || (e.target.tagName === 'IMG')) clear();
      });
    }
  </script>
</Base>

<style>
  .detail{padding-top:24px}
  .map-head.retro-head{display:flex;justify-content:space-between;align-items:flex-end;padding-top:8px}
  .badges{display:flex;gap:8px;margin-bottom:10px}
  .theme-badge{font-size:12px;font-weight:700;padding:5px 12px;border-radius:8px;background:rgba(176,107,255,.16);color:var(--neutral)}
  .size-badge{font-size:12px;padding:5px 12px;border-radius:8px;background:var(--bg-elev);color:var(--txt-dim);border:1px solid var(--line)}
  .map-head h1.neon-title{font-size:36px;font-weight:900;text-shadow:0 0 12px rgba(255,216,78,.3)}
  .map-en{font-size:14px;color:var(--txt-dim);margin-top:2px}
  .meta{font-size:12px;color:var(--txt-dim);margin-top:4px}
  .lead{color:var(--txt-dim);font-size:16px;margin:14px 0 4px;max-width:720px}
  .detail-layout{display:grid;grid-template-columns:1fr 300px;gap:28px;margin-bottom:40px}
  .sec{background:var(--bg-card);border:1px solid var(--line);border-radius:16px;padding:22px;margin-bottom:18px}
  .sec h2{font-size:17px;color:var(--accent);margin-bottom:12px}
  .hint{font-size:13px;color:var(--txt-dim);margin-bottom:14px}

  /* Map viewer: base image + pins */
  .map-viewer{
    position:relative;
    line-height:0;
    border-radius:16px;
    overflow:hidden;
    border:1px solid var(--line);
    box-shadow: 0 10px 30px -10px rgba(0,0,0,.5),
                0 0 0 1px rgba(255,255,255,.05) inset;
    transition: transform .3s ease, box-shadow .3s ease;
  }
  .map-viewer:hover {
    transform: scale(1.005);
    box-shadow: 0 15px 40px -8px rgba(0,0,0,.6),
                0 0 0 1px rgba(255,255,255,.08) inset;
  }
  .map-viewer img{
    width:100%;height:auto;display:block;
    transition: filter .4s ease;
  }
  .map-viewer:hover img { filter: contrast(1.05) saturate(1.1); }

  .pin{
    position:absolute;
    transform:translate(-50%,-50%);
    background:none;
    border:none;
    cursor:pointer;
    padding:0;
    z-index:1;
    transition: transform .2s cubic-bezier(0.23,1,0.32,1);
  }
  .pin-dot{
    display:block;
    width:18px;height:18px;
    border-radius:50%;
    background:var(--pc);
    box-shadow: 0 0 0 4px rgba(0,0,0,.4), 
                0 0 0 8px rgba(255,255,255,.1),
                0 0 18px 3px var(--pc);
    transition: transform .2s ease, box-shadow .2s ease;
    animation: pinPulse 2s infinite ease-in-out;
  }
  @keyframes pinPulse {
    0%,100% { transform: scale(1); }
    50% { transform: scale(1.15); }
  }
  .pin:hover{z-index:10}
  .pin:hover .pin-dot{
    transform:scale(1.6);
    box-shadow: 0 0 0 5px rgba(0,0,0,.3), 
                0 0 0 12px rgba(255,255,255,.15),
                0 0 25px 6px var(--pc);
  }
  .pin.active .pin-dot {
    animation: none;
    transform: scale(1.8);
    box-shadow: 0 0 0 6px rgba(255,255,255,.4), 0 0 30px 8px var(--pc);
  }

  .pin-pop{
    position:absolute;
    bottom:150%;left:50%;
    transform:translateX(-50%);
    background:var(--bg-elev);
    border:2px solid var(--pc);
    border-radius:12px;
    padding:10px 14px;
    width:220px;
    text-align:left;
    opacity:0;
    pointer-events:none;
    transition: all .25s cubic-bezier(0.23,1,0.32,1);
    line-height:1.5;
    z-index:20;
    box-shadow: 0 8px 25px rgba(0,0,0,.4);
  }
  .pin:hover .pin-pop,
  .pin:focus .pin-pop,
  .pin.active .pin-pop {
    opacity:1;
    pointer-events:auto;
    bottom:160%;
  }
  .pin-pop strong{display:block;font-size:14px;color:var(--txt);margin-bottom:4px}
  .pin-pop em{font-size:12px;color:var(--txt-dim);font-style:normal}

  /* Legend */
  .legend{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px}
  .leg{
    display:flex;align-items:center;gap:6px;
    font-size:12px;color:var(--txt-dim);
    background:var(--bg-elev);border:1px solid var(--line);
    padding:4px 10px;border-radius:var(--radius-sm);
    cursor:pointer;transition:all var(--trans-fast);
  }
  .leg i{width:11px;height:11px;border-radius:50%}
  .leg:hover{border-color:var(--accent);color:var(--txt)}
  .leg.active{background:var(--accent);color:#151229;border-color:var(--accent);font-weight:700}

  .pin.active .pin-dot {
    transform: scale(1.6);
    box-shadow: 0 0 0 4px rgba(255,255,255,.3), 0 0 14px 2px var(--pc);
  }
  .pin.active .pin-pop {
    opacity: 1;
    pointer-events: auto;
  }

  /* Faction strategies */
  .camp-strats{display:flex;flex-direction:column;gap:14px}
  .camp-strat{border-left:3px solid var(--cc);padding-left:14px}
  .camp-strat h3{font-size:15px;color:var(--cc);margin-bottom:8px}
  .camp-strat ul{list-style:none;display:flex;flex-direction:column;gap:7px}
  .camp-strat li{font-size:14px;color:var(--txt-dim);padding-left:16px;position:relative}
  .camp-strat li::before{content:"▸";position:absolute;left:0;color:var(--cc)}
  .tips{list-style:none;display:flex;flex-direction:column;gap:9px}
  .tips li{font-size:14.5px;color:var(--txt-dim);padding-left:18px;position:relative}
  .tips li::before{content:"▸";position:absolute;left:0;color:var(--accent)}

  /* Sidebar */
  .mini h2{font-size:15px}
  .feat-table{width:100%;border-collapse:collapse}
  .feat-table td{padding:7px 0;font-size:13.5px;border-bottom:1px solid var(--line)}
  .feat-table td:first-child{color:var(--txt-dim)}
  .feat-table td.yes{color:var(--accent);text-align:right;font-weight:700}
  .feat-table td.no{color:var(--txt-dim);text-align:right}
  .sabos{margin-top:14px;display:flex;flex-wrap:wrap;gap:6px;align-items:center}
  .sabo-title{font-size:12px;color:var(--txt-dim);width:100%;margin-bottom:4px}
  .sabo{font-size:11px;background:rgba(251,146,60,.16);color:#fb923c;padding:3px 9px;border-radius:6px}
  .rel{display:block;padding:9px 0;border-bottom:1px solid var(--line);font-size:14px}
  .rel:last-child{border:0}
  .rel span{color:var(--txt-dim);font-size:12px}
  .rel:hover{color:var(--accent)}

  @media(max-width:920px){
    .detail-layout{grid-template-columns:1fr}
    .ad-side{display:none}
    .map-head h1{font-size:28px}
    .pin-pop{width:160px}
  }
</style>
