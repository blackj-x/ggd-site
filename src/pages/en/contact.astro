---
import Base from '../../layouts/Base.astro';
import InfoSection from '../../components/InfoSection.astro';

const lang = 'en';

const title = 'Contact Us - Goose Goose Duck Guide';
const description =
  'Contact the Goose Goose Duck Guide team: if you find data errors, have content suggestions, or have copyright/collaboration questions, feel free to email us. We will reply as soon as possible.';

const CONTACT_EMAIL = 'support@metaup.pro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ContactPage',
      name: title,
      description,
      inLanguage: 'en',
      url: new URL('/en/contact/', Astro.site).href,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/en/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: 'Contact Us' },
      ],
    },
  ],
};
---
<Base title={title} description={description} jsonLd={jsonLd} lang={lang}>
  <div class="wrap detail">
    <div class="crumb"><a href="/en/">Home</a> / Contact Us</div>
    <h1>Contact<span class="em"> Us</span></h1>
    <p class="lead">The Goose Goose Duck Guide is run by a real team. Whether you spot data errors in the guides, want to suggest new content, or have copyright or collaboration questions — we’d love to hear from you.</p>

    <div class="detail-layout-single">
      <main>
        <InfoSection title="Email Contact" icon="📧">
          <p>This is our main channel. Please send emails to:</p>
          <p class="email"><a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a></p>
          <p class="hint">We usually reply within a few business days. To help us process your message faster, please mention the specific page, role, or map you’re referring to.</p>
        </InfoSection>

        <InfoSection title="We Welcome Messages About" icon="📝">
          <ul class="kv">
            <li><strong>Corrections</strong>: If a skill, mechanic, or strategy description doesn’t match the actual game — send the page you saw and the correct info. We will verify and fix.</li>
            <li><strong>Content Suggestions</strong>: Want us to add a role, map, or specific guide topic.</li>
            <li><strong>Copyright Issues</strong>: If you are a rights holder and believe something on the site is problematic, please explain and we will handle it promptly.</li>
            <li><strong>Collaboration & Other</strong>: Partnership ideas related to the guide network or content.</li>
          </ul>
        </InfoSection>

        <InfoSection title="About Your Messages" icon="🔒">
          <p>The email address and content you voluntarily send us <strong>will only be used to reply to and handle your specific request</strong>. It will not be used for mass marketing and will not be sold or shared with third parties. See our <a href="/en/privacy/">Privacy Policy</a> for details.</p>
        </InfoSection>

        <InfoSection title="You Might Also Be Looking For" icon="👉" variant="compact">
          <p>To learn more about the site’s focus and data sources, see <a href="/en/about/">About</a>. New players can start with the <a href="/en/guide/">Beginner Guide</a>.</p>
        </InfoSection>
      </main>
    </div>
  </div>
</Base>

<style>
  .detail{padding-top:24px}
  h1{font-size:38px;font-weight:900;letter-spacing:-.5px;margin-top:6px}
  h1 .em{background:linear-gradient(120deg,var(--goose),var(--neutral) 50%,var(--duck));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
  .lead{color:var(--txt-dim);font-size:16.5px;margin:14px 0 18px;max-width:760px}
  .detail-layout-single{max-width:820px;margin-bottom:40px}
  .sec strong{color:var(--txt)}
  .hint{font-size:13px;color:var(--txt-dim)!important}
  .email{font-size:18px;font-weight:700;margin:6px 0 8px}
  .email a{color:var(--accent)}
  .kv{list-style:none;display:flex;flex-direction:column;gap:9px;margin:4px 0 4px}
  .kv li{font-size:15px;color:var(--txt-dim);line-height:1.65;padding-left:18px;position:relative}
  .kv li::before{content:'›';position:absolute;left:0;top:-1px;color:var(--accent);font-weight:700}
  .kv li strong{color:var(--txt)}
  .next p{color:var(--txt-dim)}
  @media(max-width:920px){h1{font-size:28px}}
</style>
