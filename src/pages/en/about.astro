---
import Base from '../../layouts/Base.astro';
import InfoSection from '../../components/InfoSection.astro';
import { roles } from '../../data/roles';
import { maps } from '../../data/maps';

const lang = 'en';

const title = 'About - Goose Goose Duck Guide';
const description =
  'About Goose Goose Duck Guide: a focused Chinese (and now English) strategy & database site for Goose Goose Duck (GGD). We organize roles, skills, camp mechanics and map points into clear, usable guides. Part of the metaup.pro game guide network.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'AboutPage',
      name: title,
      description,
      inLanguage: 'en',
      url: new URL('/en/about/', Astro.site).href,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/en/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: 'About' },
      ],
    },
  ],
};
---
<Base title={title} description={description} jsonLd={jsonLd} lang={lang}>
  <div class="wrap detail">
    <div class="crumb"><a href="/en/">Home</a> / About</div>
    <h1>About<span class="em"> the Site</span></h1>
    <p class="lead">Goose Goose Duck Guide is a strategy and reference database focused on Goose Goose Duck (GGD). We reorganize the game's many roles, skills, faction mechanics, and map points into clear, practical English (and Chinese) guides so players can quickly look things up before a match.</p>

    <div class="detail-layout-single">
      <main>
        <InfoSection title="What This Site Is" icon="🎯">
          <p>A practical, searchable reference for <strong>Goose Goose Duck</strong>. Currently includes:</p>
          <ul class="kv">
            <li><strong>Role Compendium ({roles.length} roles)</strong>: Detailed skills, win conditions, kill/vote ability, and practical tips for every Goose, Duck, and Neutral role.</li>
            <li><strong>Map Guides ({maps.length} maps)</strong>: Task locations, key routes, kill spots, and vision blind spots with original map diagrams.</li>
            <li><strong>Beginner & Advanced Guides</strong>: Rules, terminology, and gameplay strategy, kept up to date with game versions.</li>
          </ul>
        </InfoSection>

        <InfoSection title="How the Content Is Made" icon="📚">
          <p>Content is <strong>independently organized and rewritten</strong> from publicly available game data. Not machine-translated copies or direct lifts:</p>
          <ul class="kv">
            <li><strong>Data fields</strong> (role camps, abilities, map tasks) come from observable in-game facts and community-maintained public sources. These are game facts.</li>
            <li><strong>Guide text</strong> (skill explanations, strategy, faction matchups) is <strong>reorganized and written in clear English</strong> after understanding the mechanics, with practical advice from actual play.</li>
            <li><strong>Map diagrams</strong> are <strong>original SVG artwork</strong> to avoid copyright issues with official screenshots.</li>
            <li>When exact values are unavailable, we mark them as “estimated/inferred”.</li>
          </ul>
          <p class="hint">The game receives frequent updates. We keep data current. If you spot errors, please let us know via the contact page.</p>
        </InfoSection>

        <InfoSection title="Who It's For" icon="👥">
          <p>Players of Goose Goose Duck who want quick, reliable information — especially new players learning roles, experienced players planning routes and kills, and anyone looking to improve meeting talk and game sense. The goal is “check here before the round starts and have the answer ready.”</p>
        </InfoSection>

        <InfoSection title="Part of the metaup.pro Network" icon="🛰">
          <p>This site belongs to the <a href="https://metaup.pro" rel="noopener" target="_blank">metaup.pro</a> game guide network. We build <strong>independent strategy sites</strong> for different games (e.g. Lethal Company Guide at lethalcompany.metaup.pro). Each site focuses on one game with its own clear system, run by the same team with consistent standards for accuracy and originality. Goose Duck Guide (gooseduck.metaup.pro) was the first in the network.</p>
        </InfoSection>

        <InfoSection title="Copyright Notice" icon="⚖️">
          <p>Goose Goose Duck and all related names and assets are the property of Gaggle Studios and its publisher. <strong>This is an unofficial player guide site and has no affiliation with the official game or its publisher.</strong> We only reference publicly available game facts for informational and strategy purposes. If rights holders have concerns, please contact us.</p>
        </InfoSection>

        <InfoSection title="Get Started" icon="👉" variant="compact">
          <p>New players: start with the <a href="/en/guide/">Beginner Guide</a>, then explore the <a href="/en/roles/">Role Compendium</a> and <a href="/en/maps/">Map Guides</a>. For how we handle data, see the <a href="/en/privacy/">Privacy Policy</a>.</p>
        </InfoSection>

        <InfoSection title="Sources & Update Policy" icon="📚">
          <p>Data fields come from observable game mechanics and public sources. All strategy text, tips, speech examples and analysis are independently written and tested by players for practical value. Update priority: official mechanics first. Every role and map shows its last updatedAt. We prioritize original organization and real-play advice over raw reproduction.</p>
          <p>Editing note: Corrections via the contact page are welcome. All content is original organization, not copy-paste. Corruption mode and other version-specific content is clearly labeled.</p>
        </InfoSection>
      </main>
    </div>
  </div>
</Base>

<style>
  .detail{padding-top:24px}
  h1{font-size:38px;font-weight:900;letter-spacing:-.5px;margin-top:6px}
  h1 .em{background:linear-gradient(120deg,var(--goose),var(--neutral) 50%,var(--duck));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
  .lead{color:var(--txt-dim);font-size:16.5px;margin:14px 0 18px;max-width:760px}
  .detail-layout-single{max-width:820px;margin-bottom:40px}
  .hint{font-size:13px;color:var(--txt-dim)!important}
  .kv{list-style:none;display:flex;flex-direction:column;gap:9px;margin:4px 0 12px}
  .kv li{font-size:15px;color:var(--txt-dim);line-height:1.65;padding-left:18px;position:relative}
  .kv li::before{content:'›';position:absolute;left:0;top:-1px;color:var(--accent);font-weight:700}
  .kv li strong{color:var(--txt)}
  .next p{color:var(--txt-dim)}
  @media(max-width:920px){h1{font-size:28px}}
</style>
