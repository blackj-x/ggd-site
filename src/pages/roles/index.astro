---
import Base from '../../layouts/Base.astro';
import AdSlot from '../../components/AdSlot.astro';
import RoleCard from '../../components/RoleCard.astro';
import { getLocalizedRoles } from '../../data/roles';
import { getLocaleFromPath, getUI, type Locale } from '../../i18n/config';

const pathname = Astro.url.pathname;
const lang: Locale = getLocaleFromPath(pathname);
const roles = getLocalizedRoles(lang);
const ui = getUI(lang);

const title = lang === 'en' 
  ? 'Role Compendium - Goose Goose Duck Guide'
  : '全角色图鉴 - 鹅鸭杀攻略社';

const description = lang === 'en'
  ? 'Goose Goose Duck full role compendium: Geese, Ducks, Neutral. Abilities, win conditions, strategies and counters.'
  : '鹅鸭杀（Goose Goose Duck）全角色图鉴：鹅、鸭、中立三大阵营技能、胜利条件、玩法要点与话术，支持按阵营筛选与关键词搜索。';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
};
---
<Base title={title} description={description} jsonLd={jsonLd} active="roles">
  <div class="wrap">
    <section class="hero retro-hero">
      <div class="crumb"><a href={lang === 'en' ? '/en/' : '/'}>{ui.home}</a> / {ui.roles}</div>
      <h1>
        <span class="title-main">{lang === 'en' ? 'Role' : '全角色'}</span>
        <span class="em">{lang === 'en' ? 'Compendium' : '图鉴'}</span>
      </h1>
      <p class="sub">{lang === 'en' ? 'All Geese, Ducks and Neutral roles with skills, win conditions and strategies. Every entry includes tested tips, real match examples and counters — not just wiki facts.' : '鹅、鸭、中立三大阵营全角色技能、胜利条件与玩法要点。每条都包含实测要点、场景建议与反制，而非简单罗列。点击卡片查看详细攻略。'}</p>
      <div class="hero-stats">
        <span class="stat">{roles.length} {lang === 'en' ? 'roles' : '角色'}</span>
        <span class="stat">3 {lang === 'en' ? 'factions' : '阵营'}</span>
      </div>
    </section>

    <section class="explained">
      <h2>角色解释 / Roles Explained</h2>
      <p class="lead">不是简单 wiki 复制。这里提供实用分层与新手优先级，帮助你快速掌握全角色，而非死记技能。</p>

      <div class="layers">
        <div>
          <strong>新手优先学习顺序（推荐）</strong>
          <ol>
            <li>加拿大鹅 / 政客（低风险信息与投票）</li>
            <li>侦探鹅 / 警长（核心查验与带刀）</li>
            <li>正义使者 / 保镖（反制与保护）</li>
            <li>模仿者 / 工程师（信息伪装与机动）</li>
            <li>中立：呆呆鸟 → 秃鹫 → 布谷鸟（v4.08）</li>
          </ol>
        </div>
        <div>
          <strong>难度分层（官方 1-3★）</strong>
          <ul>
            <li>★ 易上手：加拿大鹅、政客、网红、专业杀手</li>
            <li>★★ 要思路：侦探、警长、工程师、跟踪者、巫医（v4.08）</li>
            <li>★★★ 高操作：刺客、忍者、变形者、清醒做梦者（v4.08）</li>
          </ul>
        </div>
        <div>
          <strong>阵营玩法倾向</strong>
          <ul>
            <li>鹅：重信息收集 + 协作投票。优先保护查验位。</li>
            <li>鸭：重伪装 + 时机破坏。迷失鸭崽 / 寄生虫组合是 v4.08 特色。</li>
            <li>中立：自保求独特胜利条件（布谷鸟产蛋狩猎是新看点）。</li>
          </ul>
        </div>
      </div>
      <p class="hint">v4.08 新角色已用「v4.08 新」标签高亮，支持上方筛选。详情页含实测话术与反制。</p>
    </section>

    <AdSlot variant="top" />

    <div class="controls">
      <div class="search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4-4"/></svg>
        <input type="text" id="q" placeholder={ui.searchPlaceholder} />
      </div>
      <div class="filters">
        <button class="chip on" data-f="all">{ui.all}</button>
        <button class="chip" data-f="goose">🦢 {ui['camp.goose']}</button>
        <button class="chip" data-f="duck">🦆 {ui['camp.duck']}</button>
        <button class="chip" data-f="neutral">🎭 {ui['camp.neutral']}</button>
        <button class="chip" data-f="v4">🆕 v4.08 新</button>
      </div>
    </div>
    <div class="count" id="count"></div>

    <div class="layout fade-in">
      <main>
        <div class="grid" id="grid">
          {roles.map((role) => <RoleCard role={role} lang={lang} />)}
        </div>
      </main>
      <aside>
        <AdSlot variant="side" />
      </aside>
    </div>
  </div>
</Base>

<style>
  .hero{padding:46px 0 26px}
  .retro-hero h1{font-size:44px;font-weight:900;letter-spacing:-1px}
  .retro-hero .title-main{display:block}
  .retro-hero h1 .em{background:linear-gradient(120deg,var(--goose),var(--neutral) 50%,var(--duck));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
  .retro-hero .sub{color:var(--txt-dim);margin-top:10px;max-width:640px}
  .hero-stats{display:flex;gap:12px;margin-top:14px;font-size:12px}
  .hero-stats .stat{padding:4px 10px;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,0.03);color:var(--txt-dim)}
  .controls{display:flex;flex-wrap:wrap;gap:var(--space-4);align-items:center;margin-bottom:8px}
  .search{flex:1;min-width:220px;position:relative}
  .search input{
    width:100%;background:var(--bg-card);border:1px solid var(--line);
    border-radius:var(--radius-md);padding:12px 14px 12px 40px;
    color:var(--txt);font-size:15px;font-family:inherit;
    transition:border-color var(--trans-fast);
  }
  .search input:focus{outline:none;border-color:var(--goose);box-shadow:0 0 0 3px rgba(59,169,255,.1)}
  .search svg{position:absolute;left:13px;top:13px;opacity:.5}
  .filters{display:flex;gap:8px;flex-wrap:wrap}
  .chip{
    background:var(--bg-card);border:1px solid var(--line);
    color:var(--txt-dim);padding:9px 16px;border-radius:999px;
    cursor:pointer;font-size:14px;transition:all var(--trans-fast);
    font-family:inherit;
  }
  .chip:hover{color:var(--txt);border-color:var(--txt-dim)}
  .chip.on{color:#151229;font-weight:700;border-color:transparent}
  .chip.on[data-f="goose"]{background:var(--goose)}
  .chip.on[data-f="duck"]{background:var(--duck)}
  .chip.on[data-f="neutral"]{background:var(--neutral)}
  .chip.on[data-f="all"]{background:var(--accent)}
  .count{font-size:13px;color:var(--txt-dim);margin:14px 0}
  .layout{display:grid;grid-template-columns:1fr 300px;gap:28px;margin:24px 0 60px}
  @media(max-width:920px){.layout{grid-template-columns:1fr}.ad-side{display:none}h1{font-size:30px}}

  .explained{margin:8px 0 20px;padding:16px 18px;background:var(--bg-card);border:1px solid var(--line);border-radius:var(--radius-lg)}
  .explained h2{font-size:18px;margin:0 0 8px;color:var(--accent)}
  .explained .lead{margin:0 0 12px;color:var(--txt-dim);font-size:14px}
  .explained .layers{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;font-size:13px}
  .explained ul,.explained ol{margin:4px 0 0 16px}
  .explained .hint{margin:10px 0 0;font-size:12px;color:var(--txt-dim)}
</style>

<script>
  // 客户端筛选/搜索：对已由 Astro 渲染好的卡片做显隐，不重建 DOM（保留 SEO）
  const cards = Array.from(document.querySelectorAll<HTMLElement>('#grid .card'));
  const count = document.getElementById('count')!;
  const q = document.getElementById('q') as HTMLInputElement;
  let filter = 'all', kw = '';

  function apply() {
    let shown = 0;
    cards.forEach((c) => {
      const camp = c.dataset.camp!;
      const isV4 = c.dataset.v4 === '1';
      const text = c.textContent!.toLowerCase();
      let ok;
      if (filter === 'v4') ok = isV4 && text.includes(kw.toLowerCase());
      else ok = (filter === 'all' || camp === filter) && text.includes(kw.toLowerCase());
      c.style.display = ok ? '' : 'none';
      if (ok) shown++;
    });
    count.textContent = `共 ${shown} 个角色`;
  }
  document.querySelectorAll<HTMLElement>('.chip').forEach((c) =>
    c.addEventListener('click', () => {
      document.querySelectorAll('.chip').forEach((x) => x.classList.remove('on'));
      c.classList.add('on');
      filter = c.dataset.f!;
      apply();
    })
  );
  q.addEventListener('input', (e) => { kw = (e.target as HTMLInputElement).value; apply(); });
  apply();
</script>
