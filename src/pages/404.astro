---
import Base from '../layouts/Base.astro';
---
<Base title="页面不存在 - 鹅鸭攻略社" description="页面未找到">
  <div class="wrap" style="padding-top:80px;padding-bottom:80px;text-align:center">
    <div style="font-size:72px">🦤</div>
    <h1 style="font-size:34px;margin:16px 0 8px">404 · 这只鸭把页面吞了</h1>
    <p style="color:var(--txt-dim);margin-bottom:24px">你要找的页面不存在，可能被鹈鹕吃掉了。</p>
    <a href="/" style="color:var(--accent);border:1px solid var(--line);padding:10px 20px;border-radius:10px;display:inline-block">← 返回首页</a>
  </div>
</Base>
