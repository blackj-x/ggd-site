---
import Base from '../layouts/Base.astro';
import AdSlot from '../components/AdSlot.astro';
import { roles, camps, campName } from '../data/roles';
import { maps, sizeLabel } from '../data/maps';

const title = '鹅鸭杀攻略社 - 全角色图鉴 / 地图 / 新手入门';
const description = '鹅鸭杀（Goose Goose Duck）中文攻略站：全角色技能图鉴、地图任务点位、新手入门与进阶话术。鹅、鸭、中立三大阵营一站掌握。';
const counts = {
  goose: roles.filter((r) => r.camp === 'goose').length,
  duck: roles.filter((r) => r.camp === 'duck').length,
  neutral: roles.filter((r) => r.camp === 'neutral').length,
};
const difficultyCounts = [1, 2, 3].map((level) => ({
  level,
  label: level === 1 ? '易上手' : level === 2 ? '要思路' : '高操作',
  count: roles.filter((r) => r.difficulty === level).length,
}));
const killCount = roles.filter((r) => r.canKill).length;
const voteCount = roles.filter((r) => r.canVote).length;
const featured = roles.slice(0, 4);
const featuredMaps = ['basement', 'ss-mothergoose', 'mallard-manor']
  .map((slug) => maps.find((m) => m.slug === slug))
  .filter(Boolean);
const annotatedMaps = maps.filter((m) => m.annotations?.length).length;
const maxDifficultyCount = Math.max(...difficultyCounts.map((d) => d.count));
---
<Base title={title} description={description} active="home">
  <div class="wrap">
    <section class="hero">
      <div class="hero-copy">
        <div class="kicker">🦢 开局前 30 秒情报板</div>
        <h1>
          <span class="title-main">鹅鸭杀</span>
          <span class="em">攻略社</span>
        </h1>
        <p class="sub">先查身份技能，再看地图刀点。<br />全角色图鉴、地图点位、新手入门，一站掌握 Goose Goose Duck。</p>
        <div class="hero-actions">
          <a class="primary-btn" href="/roles/">查角色</a>
          <a class="ghost-btn" href="/maps/">看地图</a>
        </div>
        <div class="hero-trust">
          <span class="trust-item">✓ 53 角色实时更新</span>
          <span class="trust-item">✓ 12 张原创标注地图</span>
        </div>
      </div>
      <div class="hero-visual retro-futurism">
        <div class="scanlines"></div>
        <img src="/home/hero-intel-board.png" alt="鹅鸭杀攻略社原创情报桌插画" fetchpriority="high" class="img-enhanced" />
        <div class="intel-board neon-glow" aria-label="站点内容统计">
          <div class="board-head">
            <span>身份情报</span>
            <strong class="glitch" data-text={roles.length}>{roles.length}</strong>
          </div>
          <div class="camp-bars">
            <div class="camp-bar goose" style={`--w:${(counts.goose / roles.length) * 100}%`}>
              <span>鹅阵营</span><b>{counts.goose}</b>
            </div>
            <div class="camp-bar duck" style={`--w:${(counts.duck / roles.length) * 100}%`}>
              <span>鸭阵营</span><b>{counts.duck}</b>
            </div>
            <div class="camp-bar neutral" style={`--w:${(counts.neutral / roles.length) * 100}%`}>
              <span>中立</span><b>{counts.neutral}</b>
            </div>
          </div>
          <div class="stat-grid">
            <div><b>{killCount}</b><span>可刀角色</span></div>
            <div><b>{voteCount}</b><span>可投票</span></div>
            <div><b>{maps.length}</b><span>地图攻略</span></div>
          </div>
        </div>
      </div>
    </section>

    <AdSlot variant="top" />

    <section class="bento fade-in">
      <a class="tile big retro-tile" href="/roles/">
        <div class="tile-kicker">三大阵营</div>
        <div class="tile-label">角色图鉴</div>
        <div class="tile-sub">{roles.length} 个身份 · 技能、胜利条件、反制关系</div>
        <div class="camp-mini neon">
          <span class="m goose">🦢 鹅 {counts.goose}</span>
          <span class="m duck">🦆 鸭 {counts.duck}</span>
          <span class="m neutral">🎭 中立 {counts.neutral}</span>
        </div>
        <img class="tile-art img-enhanced" src="/home/camp-overview.png" alt="鹅、鸭、中立三阵营原创插画" loading="lazy" />
        <div class="difficulty-chart" aria-label="角色难度分布">
          {difficultyCounts.map((d) => (
            <div class="diff-row">
              <span>{d.label}</span>
              <i style={`--w:${(d.count / maxDifficultyCount) * 100}%`}></i>
              <b>{d.count}</b>
            </div>
          ))}
        </div>
        <div class="tile-glow"></div>
      </a>
      <a class="tile map-tile retro-tile" href="/maps/">
        <div class="tile-kicker">{annotatedMaps} 张已标注</div>
        <div class="tile-label">地图攻略</div>
        <div class="tile-sub">任务点位、刀点、藏尸区与地图机制</div>
        <img class="tile-art map-art img-enhanced" src="/home/map-strategy-board.png" alt="地图路线与点位原创战术板插画" loading="lazy" />
        <div class="map-strip neon-strip">
          {featuredMaps.map((m) => (
            <img src={m.image} alt={`${m.name} 地图示意图`} loading="lazy" class="img-enhanced" />
          ))}
        </div>
        <div class="tile-glow"></div>
      </a>
      <a class="tile guide-tile retro-tile" href="/guide/">
        <div class="tile-kicker">新手第一局</div>
        <div class="tile-label">新手入门</div>
        <div class="tile-sub">三阵营目标与常用黑话</div>
        <div class="guide-list neon">
          <span>发言别自爆</span>
          <span>先记会议节奏</span>
          <span>看懂胜利条件</span>
        </div>
        <div class="tile-glow"></div>
      </a>
    </section>

    <section class="maps-showcase fade-in">
      <div class="section-head">
        <div>
          <h2>热门地图速览</h2>
          <p>用原创示意图快速抓住路线、会议点和高风险区域。</p>
        </div>
        <a href="/maps/">全部地图 →</a>
      </div>
      <div class="map-preview-grid">
        {featuredMaps.map((m) => (
          <a class="map-preview" href={`/maps/${m.slug}/`}>
            <img src={m.image} alt={`${m.name} 地图示意图`} loading="lazy" class="img-enhanced" />
            <div>
              <strong>{m.name}</strong>
              <span>{sizeLabel[m.size]} · {m.annotations?.length || 0} 个标注点</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="feat fade-in">
      <h2>热门角色</h2>
      <div class="grid">
        {featured.map((r) => (
          <a class="card" data-camp={r.camp} href={`/roles/${r.slug}/`}>
            <div class="card-top"><div class="avatar">{r.icon}</div><span class={`badge ${r.camp}`}>{campName[r.camp]}</span></div>
            <h3>{r.name}</h3><div class="role-en">{r.nameEn}</div>
            <p class="desc">{r.summary}</p>
          </a>
        ))}
      </div>
    </section>
  </div>
</Base>

<style>
  .hero{padding:54px 0 30px;display:grid;grid-template-columns:minmax(0,.86fr) minmax(460px,1.14fr);gap:30px;align-items:center}
  .kicker{color:var(--accent);font-size:13px;font-weight:900;letter-spacing:2px;margin-bottom:8px;text-transform:uppercase;opacity:.9}
  h1{font-size:56px;font-weight:900;line-height:1.05;letter-spacing:-1px}
  h1 .title-main{display:block}
  h1 .em{background:linear-gradient(120deg,var(--goose),var(--neutral) 50%,var(--duck));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;font-size:0.92em}
  .sub{color:var(--txt-dim);margin-top:12px;max-width:620px;font-size:17px;line-height:1.45}
  .hero-actions{display:flex;gap:14px;margin-top:28px;flex-wrap:wrap}
  .hero-trust{display:flex;gap:16px;margin-top:18px;font-size:12px;color:var(--txt-dim);opacity:.85}
  .trust-item{display:flex;align-items:center;gap:4px}
  .primary-btn,.ghost-btn{min-height:46px;padding:11px 22px;border-radius:10px;font-weight:900;display:inline-flex;align-items:center;justify-content:center;font-size:15px;transition:all .2s cubic-bezier(0.23,1,0.32,1)}
  .primary-btn{background:var(--accent);color:#151229;box-shadow:0 4px 14px rgba(255,216,78,.3)}
  .primary-btn:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(255,216,78,.45)}
  .ghost-btn{border:1px solid var(--line);background:rgba(36,31,69,.65);color:var(--txt);backdrop-filter:blur(8px)}
  .ghost-btn:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-1px)}
  .hero-visual{position:relative;border:1px solid var(--line);border-radius:20px;overflow:hidden;min-height:380px;background:var(--bg-card);box-shadow:0 30px 80px -20px rgba(0,0,0,.7)}
  .hero-visual.retro-futurism { position: relative; }
  .hero-visual.retro-futurism::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(transparent, transparent 3px, rgba(255,255,255,0.04) 3px, rgba(255,255,255,0.04) 4px);
    pointer-events: none;
    z-index: 2;
    mix-blend-mode: screen;
  }
  .scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(transparent, transparent 2px, rgba(0,0,0,0.25) 2px, rgba(0,0,0,0.25) 4px);
    pointer-events: none;
    z-index: 3;
    animation: scan 4s linear infinite;
  }
  @keyframes scan {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(400%); }
  }
  .hero-visual>img{width:100%;height:100%;min-height:380px;display:block;object-fit:cover}
  .intel-board{
    position:absolute;left:18px;bottom:18px;width:min(380px,calc(100% - 36px));
    border:1px solid rgba(255,255,255,0.15);
    border-radius:16px;
    background:linear-gradient(145deg,rgba(30,26,58,0.95),rgba(21,18,41,0.92));
    padding:18px;
    box-shadow:0 20px 50px -15px rgba(0,0,0,.8),
               inset 0 1px 0 rgba(255,255,255,0.1);
    backdrop-filter:blur(16px);
    z-index:4;
  }
  .intel-board.neon-glow {
    box-shadow: 0 20px 50px -15px rgba(0,0,0,.8),
                0 0 15px rgba(176,107,255,0.2),
                inset 0 1px 0 rgba(255,255,255,0.1);
  }
  .board-head{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:14px}
  .board-head span{color:var(--txt-dim);font-size:12px;letter-spacing:1px}
  .board-head strong{font-size:42px;line-height:1;color:var(--accent);font-weight:900}
  .glitch { position: relative; }
  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
  }
  .glitch::before { color: var(--goose); animation: glitch-1 1.5s infinite linear alternate-reverse; }
  .glitch::after { color: var(--duck); animation: glitch-2 2s infinite linear alternate-reverse; }
  @keyframes glitch-1 { 0%{transform:translate(0)} 20%{transform:translate(-2px,1px)} 40%{transform:translate(-1px,-1px)} 60%{transform:translate(2px,1px)} 80%{transform:translate(1px,-1px)} 100%{transform:translate(0)} }
  @keyframes glitch-2 { 0%{transform:translate(0)} 20%{transform:translate(2px,-1px)} 40%{transform:translate(1px,2px)} 60%{transform:translate(-1px,-2px)} 80%{transform:translate(-2px,1px)} 100%{transform:translate(0)} }
  .camp-bars{display:grid;gap:8px}
  .camp-bar{position:relative;display:flex;justify-content:space-between;gap:10px;padding:8px 12px;border-radius:8px;overflow:hidden;background:var(--bg-elev);font-size:12px;border:1px solid rgba(255,255,255,0.06)}
  .camp-bar::before{content:"";position:absolute;inset:0 auto 0 0;width:var(--w);opacity:.4;transition:width .6s cubic-bezier(0.23,1,0.32,1)}
  .camp-bar span,.camp-bar b{position:relative;z-index:1}
  .camp-bar.goose::before{background:var(--goose)}
  .camp-bar.duck::before{background:var(--duck)}
  .camp-bar.neutral::before{background:var(--neutral)}
  .stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:12px}
  .stat-grid div{background:rgba(21,18,41,.8);border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:9px 10px;font-size:11px}
  .stat-grid b{display:block;font-size:20px;color:var(--txt);line-height:1}
  .stat-grid span{display:block;color:var(--txt-dim);font-size:10px;margin-top:1px}
  .bento{display:grid;grid-template-columns:2fr 1fr 1fr;gap:16px;margin:14px 0 40px}
  .tile{
    background:var(--bg-card);
    border:1px solid var(--line);
    border-radius:18px;
    padding:22px;
    min-height:210px;
    display:flex;
    flex-direction:column;
    transition:transform .3s cubic-bezier(0.23,1,0.32,1), 
               box-shadow .3s cubic-bezier(0.23,1,0.32,1), 
               border-color .2s;
    position:relative;
    overflow:hidden;
    box-shadow:0 8px 25px -8px rgba(0,0,0,.4);
  }
  .tile.retro-tile {
    border-color: rgba(176,107,255,0.3);
  }
  .tile::before{content:"";position:absolute;inset:0 0 auto 0;height:4px;background:linear-gradient(90deg,var(--goose),var(--neutral),var(--duck));opacity:.9}
  .tile-glow {
    position:absolute;
    inset:-1px;
    background:linear-gradient(45deg,transparent,rgba(255,216,78,0.08),transparent);
    opacity:0;
    transition:opacity .3s;
    pointer-events:none;
  }
  .tile:hover .tile-glow { opacity:1; }
  .tile:hover{
    transform:translateY(-8px) scale(1.015);
    border-color:var(--accent);
    box-shadow:0 25px 60px -15px rgba(176,107,255,.5);
  }
  .tile.big{min-height:260px}
  .tile-label{font-size:22px;font-weight:900;letter-spacing:-0.3px}
  .tile-sub{color:var(--txt-dim);font-size:13.5px;margin-top:4px;line-height:1.35}
  .camp-mini{display:flex;gap:8px;margin-top:12px;flex-wrap:wrap}
  .camp-mini.neon .m {
    padding:4px 10px;
    border-radius:6px;
    background:var(--bg-elev);
    border:1px solid rgba(255,255,255,0.1);
    font-size:12px;
  }
  .camp-mini .goose{color:var(--goose)}.camp-mini .duck{color:var(--duck)}.camp-mini .neutral{color:var(--neutral)}
  .difficulty-chart{display:grid;gap:6px;margin-top:auto;padding-top:14px}
  .tile-art{width:100%;height:108px;object-fit:cover;border-radius:10px;border:1px solid var(--line);background:var(--bg-elev);margin-top:14px}
  .tile.big .tile-art{height:120px;object-position:center}
  .map-art{height:100px;object-position:center}
  .tile.big .difficulty-chart{margin-top:0}
  .diff-row{display:grid;grid-template-columns:52px 1fr 22px;gap:6px;align-items:center;font-size:11px;color:var(--txt-dim)}
  .diff-row i{height:6px;border-radius:99px;background:var(--bg-elev);position:relative;overflow:hidden}
  .diff-row i::before{content:"";position:absolute;inset:0 auto 0 0;width:var(--w);border-radius:inherit;background:linear-gradient(90deg,var(--goose),var(--accent))}
  .diff-row b{color:var(--txt);font-style:normal;text-align:right;font-weight:700}
  .map-strip{display:flex;gap:6px;margin-top:auto;padding-top:12px}
  .map-strip img{width:32%;height:58px;object-fit:cover;border-radius:6px;border:1px solid var(--line);background:var(--bg-elev)}
  .neon-strip img { transition: transform .3s, filter .3s; }
  .neon-strip:hover img { transform: scale(1.08); filter: saturate(1.2) brightness(1.1); }
  .guide-list{display:grid;gap:6px;margin-top:auto;padding-top:12px}
  .guide-list.neon span{font-size:12px;color:var(--txt);background:var(--bg-elev);border:1px solid rgba(255,216,78,0.3);border-radius:6px;padding:6px 10px}
  .maps-showcase{margin:0 0 42px}
  .section-head{display:flex;justify-content:space-between;gap:18px;align-items:flex-end;margin-bottom:16px}
  .section-head h2,.feat h2{font-size:22px;margin-bottom:4px;font-weight:800}
  .section-head p{color:var(--txt-dim);font-size:14px}
  .section-head a{color:var(--accent);font-size:14px;font-weight:900}
  .map-preview-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
  .map-preview{display:grid;grid-template-columns:128px 1fr;gap:14px;align-items:center;background:rgba(36,31,69,.82);border:1px solid var(--line);border-radius:16px;padding:12px;transition:.18s}
  .map-preview:hover{transform:translateY(-4px);border-color:var(--accent);box-shadow:0 10px 25px -8px rgba(176,107,255,.3)}
  .map-preview img{width:128px;height:82px;object-fit:cover;border-radius:10px;background:var(--bg-elev);border:1px solid var(--line)}
  .map-preview strong{display:block;font-size:17px}
  .map-preview span{display:block;color:var(--txt-dim);font-size:13px;margin-top:4px}
  .feat h2{font-size:22px;margin-bottom:16px}
  .retro-tile { position: relative; }
  .retro-tile::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(transparent, rgba(255,216,78,0.03));
    opacity: 0;
    transition: opacity .3s;
    pointer-events: none;
  }
  .retro-tile:hover::after { opacity: 1; }
  @media(max-width:1040px){.hero{grid-template-columns:1fr}.hero-visual{max-width:720px}.bento,.map-preview-grid{grid-template-columns:1fr}.map-preview{grid-template-columns:112px 1fr}.map-preview img{width:112px}}
  @media(max-width:920px){h1{font-size:40px}.hero{padding-top:34px}.stat-grid{grid-template-columns:1fr 1fr 1fr}.section-head{align-items:flex-start;flex-direction:column}.hero-visual,.hero-visual>img{min-height:300px}.intel-board{position:relative;left:auto;bottom:auto;width:auto;margin:12px}}
  @media(max-width:560px){.stat-grid{grid-template-columns:1fr}.map-preview{grid-template-columns:1fr}.map-preview img{width:100%;height:150px}.tile{min-height:0}.tile.big{min-height:0}}
</style>
