---
import Base from '../layouts/Base.astro';
import AdSlot from '../components/AdSlot.astro';
import { roles, camps, campName } from '../data/roles';
import { maps, sizeLabel } from '../data/maps';

const title = '鹅鸭杀攻略社 - 全角色图鉴 / 地图 / 新手入门';
const description = '鹅鸭杀（Goose Goose Duck）中文攻略站：全角色技能图鉴、地图任务点位、新手入门与进阶话术。鹅、鸭、中立三大阵营一站掌握。';
const counts = {
  goose: roles.filter((r) => r.camp === 'goose').length,
  duck: roles.filter((r) => r.camp === 'duck').length,
  neutral: roles.filter((r) => r.camp === 'neutral').length,
};
const difficultyCounts = [1, 2, 3].map((level) => ({
  level,
  label: level === 1 ? '易上手' : level === 2 ? '要思路' : '高操作',
  count: roles.filter((r) => r.difficulty === level).length,
}));
const killCount = roles.filter((r) => r.canKill).length;
const voteCount = roles.filter((r) => r.canVote).length;
const featured = roles.slice(0, 4);
const featuredMaps = ['basement', 'ss-mothergoose', 'mallard-manor']
  .map((slug) => maps.find((m) => m.slug === slug))
  .filter(Boolean);
const annotatedMaps = maps.filter((m) => m.annotations?.length).length;
const maxDifficultyCount = Math.max(...difficultyCounts.map((d) => d.count));
---
<Base title={title} description={description} active="home">
  <div class="wrap">
    <section class="hero">
      <div class="hero-copy">
        <div class="kicker">开局前 30 秒情报板</div>
        <h1>鹅鸭杀<span class="em">攻略社</span></h1>
        <p class="sub">先查身份技能，再看地图刀点。全角色图鉴、地图点位、新手入门，一站掌握 Goose Goose Duck。</p>
        <div class="hero-actions">
          <a class="primary-btn" href="/roles/">查角色</a>
          <a class="ghost-btn" href="/maps/">看地图</a>
        </div>
      </div>
      <div class="hero-visual">
        <img src="/home/hero-intel-board.png" alt="鹅鸭杀攻略社原创情报桌插画" fetchpriority="high" />
        <div class="intel-board" aria-label="站点内容统计">
          <div class="board-head">
            <span>身份情报</span>
            <strong>{roles.length}</strong>
          </div>
          <div class="camp-bars">
            <div class="camp-bar goose" style={`--w:${(counts.goose / roles.length) * 100}%`}>
              <span>鹅阵营</span><b>{counts.goose}</b>
            </div>
            <div class="camp-bar duck" style={`--w:${(counts.duck / roles.length) * 100}%`}>
              <span>鸭阵营</span><b>{counts.duck}</b>
            </div>
            <div class="camp-bar neutral" style={`--w:${(counts.neutral / roles.length) * 100}%`}>
              <span>中立</span><b>{counts.neutral}</b>
            </div>
          </div>
          <div class="stat-grid">
            <div><b>{killCount}</b><span>可刀角色</span></div>
            <div><b>{voteCount}</b><span>可投票</span></div>
            <div><b>{maps.length}</b><span>地图攻略</span></div>
          </div>
        </div>
      </div>
    </section>

    <AdSlot variant="top" />

    <section class="bento">
      <a class="tile big" href="/roles/">
        <div class="tile-kicker">三大阵营</div>
        <div class="tile-label">角色图鉴</div>
        <div class="tile-sub">{roles.length} 个身份 · 技能、胜利条件、反制关系</div>
        <div class="camp-mini">
          <span class="m goose">鹅 {counts.goose}</span>
          <span class="m duck">鸭 {counts.duck}</span>
          <span class="m neutral">中立 {counts.neutral}</span>
        </div>
        <img class="tile-art" src="/home/camp-overview.png" alt="鹅、鸭、中立三阵营原创插画" loading="lazy" />
        <div class="difficulty-chart" aria-label="角色难度分布">
          {difficultyCounts.map((d) => (
            <div class="diff-row">
              <span>{d.label}</span>
              <i style={`--w:${(d.count / maxDifficultyCount) * 100}%`}></i>
              <b>{d.count}</b>
            </div>
          ))}
        </div>
      </a>
      <a class="tile map-tile" href="/maps/">
        <div class="tile-kicker">{annotatedMaps} 张已标注</div>
        <div class="tile-label">地图攻略</div>
        <div class="tile-sub">任务点位、刀点、藏尸区与地图机制</div>
        <img class="tile-art map-art" src="/home/map-strategy-board.png" alt="地图路线与点位原创战术板插画" loading="lazy" />
        <div class="map-strip">
          {featuredMaps.map((m) => (
            <img src={m.image} alt={`${m.name} 地图示意图`} loading="lazy" />
          ))}
        </div>
      </a>
      <a class="tile guide-tile" href="/guide/">
        <div class="tile-kicker">新手第一局</div>
        <div class="tile-label">新手入门</div>
        <div class="tile-sub">三阵营目标与常用黑话</div>
        <div class="guide-list">
          <span>发言别自爆</span>
          <span>先记会议节奏</span>
          <span>看懂胜利条件</span>
        </div>
      </a>
    </section>

    <section class="maps-showcase">
      <div class="section-head">
        <div>
          <h2>热门地图速览</h2>
          <p>用原创示意图快速抓住路线、会议点和高风险区域。</p>
        </div>
        <a href="/maps/">全部地图 →</a>
      </div>
      <div class="map-preview-grid">
        {featuredMaps.map((m) => (
          <a class="map-preview" href={`/maps/${m.slug}/`}>
            <img src={m.image} alt={`${m.name} 地图示意图`} loading="lazy" />
            <div>
              <strong>{m.name}</strong>
              <span>{sizeLabel[m.size]} · {m.annotations?.length || 0} 个标注点</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="feat">
      <h2>热门角色</h2>
      <div class="grid">
        {featured.map((r) => (
          <a class="card" data-camp={r.camp} href={`/roles/${r.slug}/`}>
            <div class="card-top"><div class="avatar">{r.icon}</div><span class={`badge ${r.camp}`}>{campName[r.camp]}</span></div>
            <h3>{r.name}</h3><div class="role-en">{r.nameEn}</div>
            <p class="desc">{r.summary}</p>
          </a>
        ))}
      </div>
    </section>
  </div>
</Base>

<style>
  .hero{padding:54px 0 30px;display:grid;grid-template-columns:minmax(0,.86fr) minmax(460px,1.14fr);gap:30px;align-items:center}
  .kicker,.tile-kicker{color:var(--accent);font-size:13px;font-weight:900;letter-spacing:1px}
  h1{font-size:54px;font-weight:900;line-height:1.08}
  h1 .em{background:linear-gradient(120deg,var(--goose),var(--neutral) 50%,var(--duck));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
  .sub{color:var(--txt-dim);margin-top:10px;max-width:640px;font-size:17px}
  .hero-actions{display:flex;gap:12px;margin-top:24px;flex-wrap:wrap}
  .primary-btn,.ghost-btn{min-height:44px;padding:10px 18px;border-radius:8px;font-weight:900;display:inline-flex;align-items:center;justify-content:center}
  .primary-btn{background:var(--accent);color:#151229}
  .ghost-btn{border:1px solid var(--line);background:rgba(36,31,69,.72);color:var(--txt)}
  .hero-visual{position:relative;border:1px solid var(--line);border-radius:18px;overflow:hidden;min-height:360px;background:var(--bg-card);box-shadow:0 26px 70px -36px rgba(59,169,255,.9)}
  .hero-visual>img{width:100%;height:100%;min-height:360px;display:block;object-fit:cover}
  .intel-board{position:absolute;left:16px;bottom:16px;width:min(360px,calc(100% - 32px));border:1px solid rgba(243,240,255,.22);border-radius:16px;background:linear-gradient(160deg,rgba(36,31,69,.92),rgba(21,18,41,.8));padding:16px;box-shadow:0 24px 60px -32px rgba(59,169,255,.9);overflow:hidden;backdrop-filter:blur(10px)}
  .intel-board::before{content:"";position:absolute;inset:0 0 auto;height:5px;background:linear-gradient(90deg,var(--goose),var(--neutral),var(--duck),var(--accent))}
  .board-head{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:16px}
  .board-head span{color:var(--txt-dim);font-size:13px}
  .board-head strong{font-size:44px;line-height:1;color:var(--accent)}
  .camp-bars{display:grid;gap:10px}
  .camp-bar{position:relative;display:flex;justify-content:space-between;gap:12px;padding:9px 11px;border-radius:8px;overflow:hidden;background:var(--bg-elev);font-size:13px}
  .camp-bar::before{content:"";position:absolute;inset:0 auto 0 0;width:var(--w);opacity:.28}
  .camp-bar span,.camp-bar b{position:relative;z-index:1}
  .camp-bar.goose::before{background:var(--goose)}
  .camp-bar.duck::before{background:var(--duck)}
  .camp-bar.neutral::before{background:var(--neutral)}
  .stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:14px}
  .stat-grid div{background:rgba(21,18,41,.64);border:1px solid var(--line);border-radius:10px;padding:12px}
  .stat-grid b{display:block;font-size:24px;color:var(--txt)}
  .stat-grid span{display:block;color:var(--txt-dim);font-size:12px;margin-top:2px}
  .bento{display:grid;grid-template-columns:2fr 1fr 1fr;gap:16px;margin:14px 0 40px}
  .tile{background:var(--bg-card);border:1px solid var(--line);border-radius:16px;padding:22px;min-height:210px;display:flex;flex-direction:column;transition:.18s;position:relative;overflow:hidden}
  .tile::before{content:"";position:absolute;inset:0 0 auto 0;height:4px;background:linear-gradient(90deg,var(--goose),var(--neutral),var(--duck))}
  .tile:hover{transform:translateY(-4px);border-color:var(--txt-dim);box-shadow:0 14px 38px -12px rgba(176,107,255,.6)}
  .tile.big{min-height:250px}
  .tile-label{font-size:22px;font-weight:900}
  .tile-sub{color:var(--txt-dim);font-size:14px;margin-top:4px}
  .camp-mini{display:flex;gap:10px;margin-top:14px;flex-wrap:wrap}
  .camp-mini .m{font-size:13px;padding:5px 11px;border-radius:8px;background:var(--bg-elev)}
  .camp-mini .goose{color:var(--goose)}.camp-mini .duck{color:var(--duck)}.camp-mini .neutral{color:var(--neutral)}
  .difficulty-chart{display:grid;gap:8px;margin-top:auto;padding-top:18px}
  .tile-art{width:100%;height:118px;object-fit:cover;border-radius:10px;border:1px solid var(--line);background:var(--bg-elev);margin-top:16px}
  .tile.big .tile-art{height:130px;object-position:center}
  .map-art{height:112px;object-position:center}
  .tile.big .difficulty-chart{margin-top:0}
  .diff-row{display:grid;grid-template-columns:52px 1fr 24px;gap:9px;align-items:center;font-size:12px;color:var(--txt-dim)}
  .diff-row i{height:8px;border-radius:99px;background:var(--bg-elev);position:relative;overflow:hidden}
  .diff-row i::before{content:"";position:absolute;inset:0 auto 0 0;width:var(--w);border-radius:inherit;background:linear-gradient(90deg,var(--goose),var(--accent))}
  .diff-row b{color:var(--txt);font-style:normal;text-align:right}
  .map-strip{display:flex;gap:8px;margin-top:auto;padding-top:18px}
  .map-strip img{width:33%;height:72px;object-fit:cover;border-radius:8px;border:1px solid var(--line);background:var(--bg-elev)}
  .guide-list{display:grid;gap:8px;margin-top:auto;padding-top:18px}
  .guide-list span{font-size:13px;color:var(--txt);background:var(--bg-elev);border:1px solid var(--line);border-radius:8px;padding:8px 10px}
  .guide-list span::before{content:"";display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--accent);margin-right:8px;vertical-align:middle}
  .maps-showcase{margin:0 0 42px}
  .section-head{display:flex;justify-content:space-between;gap:18px;align-items:flex-end;margin-bottom:16px}
  .section-head h2,.feat h2{font-size:22px;margin-bottom:4px}
  .section-head p{color:var(--txt-dim);font-size:14px}
  .section-head a{color:var(--accent);font-size:14px;font-weight:900}
  .map-preview-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
  .map-preview{display:grid;grid-template-columns:128px 1fr;gap:14px;align-items:center;background:rgba(36,31,69,.82);border:1px solid var(--line);border-radius:16px;padding:12px;transition:.18s}
  .map-preview:hover{transform:translateY(-4px);border-color:var(--txt-dim)}
  .map-preview img{width:128px;height:82px;object-fit:cover;border-radius:10px;background:var(--bg-elev);border:1px solid var(--line)}
  .map-preview strong{display:block;font-size:17px}
  .map-preview span{display:block;color:var(--txt-dim);font-size:13px;margin-top:4px}
  .feat h2{font-size:22px;margin-bottom:16px}
  @media(max-width:1040px){.hero{grid-template-columns:1fr}.hero-visual{max-width:720px}.bento,.map-preview-grid{grid-template-columns:1fr}.map-preview{grid-template-columns:112px 1fr}.map-preview img{width:112px}}
  @media(max-width:920px){h1{font-size:38px}.hero{padding-top:34px}.stat-grid{grid-template-columns:1fr 1fr 1fr}.section-head{align-items:flex-start;flex-direction:column}.hero-visual,.hero-visual>img{min-height:300px}.intel-board{position:relative;left:auto;bottom:auto;width:auto;margin:12px}}
  @media(max-width:560px){.stat-grid{grid-template-columns:1fr}.map-preview{grid-template-columns:1fr}.map-preview img{width:100%;height:150px}.tile{min-height:0}.tile.big{min-height:0}}
</style>
